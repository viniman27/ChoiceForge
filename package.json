{
  "name": "choiceforge",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.1"
  },
  "scripts": {
    "dev": "vite",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest",
    "test:ui:coverage": "vitest run --coverage",
    "test:all": "npm run test && npm run test:ui",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cf:preview": "npm run build && npx wrangler pages dev dist",
    "cf:deploy": "npm run build && npx wrangler pages deploy dist",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icons": "tauri icon src-tauri/app-icon.png"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.8.0",
    "vite": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.7"
  }
}
